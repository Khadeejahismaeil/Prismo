# Copy this file to .env.local and fill in your key (.env.local is gitignored).

# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Which model reviews the design. Any vision model slug from
# https://openrouter.ai/models works. Defaults to Claude Opus 4.1.
OPENROUTER_MODEL=anthropic/claude-opus-4.1

# Set to 1 to skip the model and return placeholder data (for testing the
# upload -> analyze -> results plumbing without spending tokens).
USE_MOCK_ANALYSIS=
