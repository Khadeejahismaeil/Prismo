# Copy this file to .env.local and fill in your key (.env.local is gitignored).

# Which AI provider powers the review. "gemini" (default) or "openrouter".
AI_PROVIDER=gemini

# --- Gemini (default provider) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Vision model. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# --- OpenRouter (used when AI_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
# Any vision model slug from https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-opus-4.1

# Set to 1 to skip the model and return placeholder data (for testing plumbing).
USE_MOCK_ANALYSIS=
